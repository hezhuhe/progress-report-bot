# ============================================================
# Feishu Project (Meego) MCP Server
# ============================================================
MEEGO_MCP_URL=https://project.feishu.cn/mcp_server/v1
MEEGO_MCP_TOKEN=m-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
MEEGO_PROJECT_KEY=your-feishu-project-key

# Workitem ID that receives the version-progress/diff comment (the "carrier")
MEEGO_REPORT_CARRIER_ID=
MEEGO_REPORT_CARRIER_TYPE_KEY=684a81a489c47be26942c57e

# 可选：sync 只扫描这一个工作项（演示用）
MEEGO_FOCUS_WORK_ITEM_ID=

# ============================================================
# Git provider 切换（可选增强；纯飞书模式无需配 git）
#   none   = 默认推荐 skill 起手值，不接 git，只分析飞书流转
#   local  = 扫本地 git 仓库（无 token）
#   gitlab = 远程 GitLab API
#   github = 远程 GitHub API
# ============================================================
GIT_PROVIDER=none

# --- Local（无需 token，直接扫本地 git 仓库）---
# 仓库根目录，默认当前目录。Skill 的预期用法：cd 到你的 repo 再跑。
LOCAL_GIT_REPO_PATH=.
# 查分支时优先用的远端前缀，空串=只看本地分支
LOCAL_GIT_REMOTE_PREFIX=origin/

# --- GitLab（GIT_PROVIDER=gitlab 时使用）---
GITLAB_API_BASE=https://git.ziniao.com/api/v4
GITLAB_TOKEN=
GITLAB_DEFAULT_PROJECT=

# --- GitHub（GIT_PROVIDER=github 时使用）---
GITHUB_API_BASE=https://api.github.com
GITHUB_TOKEN=
GITHUB_DEFAULT_REPO=

# ============================================================
# 视为「已合并到测试」的目标分支（逗号分隔）
# ============================================================
# 黑客松仓库的工作流：feature → pre → master，所以填 pre
# 若你的工作流是 feature → test，就填 test
MERGE_TARGET_BRANCHES=pre

# ============================================================
# Sync (F5)
# ============================================================
SYNC_SOURCE_NODE_NAME=功能开发
SYNC_TARGET_NODE_NAMES=功能测试,提测,测试中

# 演示安全护栏：只允许 sync 改这些分支对应的工作项（逗号分隔；留空=不限制）
SYNC_BRANCH_WHITELIST=heikesong_test

# ============================================================
# Report window
# ============================================================
REPORT_WINDOW_DAYS=7

# ============================================================
# --scope project / all（全员扫描）需要的配置
# ============================================================
# 默认扫描"执行需求"类型；若团队工作流主类型不同（如「需求」「迭代」），改这行
MEEGO_SCAN_TYPES=执行需求
# 留空时 fetcher 会自动调 search_project_info 查出来；预填能省一次 API
MEEGO_SPACE_SIMPLE_NAME=
